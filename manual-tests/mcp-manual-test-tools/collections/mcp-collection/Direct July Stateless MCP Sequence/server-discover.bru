meta {
  name: Server Discover
  type: http
  seq: 1
}

post {
  url: {{tower_mcp_url}}
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  MCP-Protocol-Version: 2026-07-28
  Mcp-Method: server/discover
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": "discover-1",
    "method": "server/discover",
    "params": {
      "_meta": {
        "io.modelcontextprotocol/protocolVersion": "2026-07-28",
        "io.modelcontextprotocol/clientInfo": {
          "name": "bruno-july-stateless-client",
          "version": "0.1.0"
        },
        "io.modelcontextprotocol/clientCapabilities": {}
      }
    }
  }
}

tests {
  const sessionId = res.headers["mcp-session-id"] || res.headers["MCP-Session-Id"] || res.headers["Mcp-Session-Id"];

  test("discovers stateless server capabilities", function () {
    expect(res.status).to.equal(200);
    expect(res.body.result).to.exist;
    expect(res.body.result.serverInfo).to.exist;
    expect(res.body.result.capabilities).to.exist;
  });

  test("does not create or return a session", function () {
    expect(sessionId).to.be.undefined;
  });
}
