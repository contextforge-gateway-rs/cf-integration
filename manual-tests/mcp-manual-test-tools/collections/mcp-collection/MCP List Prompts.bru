meta {
  name: MCP List Prompts
  type: http
  seq: 7
}

post {
  url: http://127.0.0.1:{{port}}/{{path}}
  body: json
  auth: inherit
}

headers {
  Accept: application/json; text/event-stream
  Content-Type: application/json
  mcp-session-id: {{mcp-session-id}}
  Authorization: {{token}}
  Connection: {{connection_action}}
  ~x-correlation-id: {{x-correlation-id}}
}

body:json {
  {"method":"prompts/list","params":{"_meta":{"progressToken":4}},"jsonrpc":"2.0","id":4}
}

settings {
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
