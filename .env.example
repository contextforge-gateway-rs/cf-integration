# Default local configuration for cf-integration.
#
# Copy this file to .env for local runs. .env is ignored by git.
# Shell variables override values from .env:
#   CF_CONTROLPLANE_REF=user/luca/dataplane-integration-fixes ./scripts/cf-integration.sh up

# cf-controlplane checkout. Default: main.
# Possible: any branch, tag, or commit accepted by git checkout.
CF_CONTROLPLANE_REF=main

# cf-controlplane repository. Default: IBM upstream.
# Possible: any git clone URL.
CF_CONTROLPLANE_REPO=https://github.com/IBM/mcp-context-forge.git

# cf-controlplane image tag used by upstream compose. Default: mcpgateway/mcpgateway:latest.
# Leave unset to use the local build tag derived from CF_CONTROLPLANE_VERSION.
# Set to a published image only when you intentionally do not want local auto-build.
# Possible: any Docker image reference.
# CF_CONTROLPLANE_IMAGE=ghcr.io/ibm/mcp-context-forge:<tag>

# Local cf-controlplane image version suffix. Default: latest.
# Used only when CF_CONTROLPLANE_IMAGE and IMAGE_LOCAL are unset.
CF_CONTROLPLANE_VERSION=latest

# Build behavior for cf-controlplane. Default: auto.
# Possible:
#   auto  - build when the default local image is missing or stamped with a different checkout revision
#   true  - always pass docker compose --build
#   false - never pass --build
CF_COMPOSE_BUILD=auto

# Fresh stack behavior. Default: true.
# Possible:
#   true  - reset compose volumes before up/test-all-up unless the running stack already matches
#   false - keep volumes; repeated up runs are faster and more idempotent
CF_FRESH_STACK=true

# Compose project names. Defaults shown.
CF_INTEGRATION_PROJECT=cf-integration
CF_CONTROLPLANE_PROJECT=cf-controlplane-only

# Generated checkout/build/runtime directory. Default: .integration.
CF_INTEGRATION_DIR=.integration

# Published cf-dataplane image. Default version is 0.1.0 because no latest tag is published.
# Possible: set CF_DATAPLANE_IMAGE to a full image ref, or CF_DATAPLANE_VERSION to a tag suffix.
# CF_DATAPLANE_IMAGE=ghcr.io/contextforge-gateway-rs/contextforge-gateway-rs:<tag>
CF_DATAPLANE_VERSION=0.1.0

# Platform for the published cf-dataplane image. Default: linux/amd64.
# Possible: linux/amd64, linux/arm64, or any platform supported by the selected image.
CF_DATAPLANE_PLATFORM=linux/amd64

# Dataplane publisher interval in seconds. Default: 2 for fast local tests.
# Possible: positive integer. Use 60 to match older/default upstream behavior.
CF_DATAPLANE_PUBLISHER_INTERVAL_SECONDS=2

# Dataplane per-user config cache TTL in seconds. Default: 0 for functional tests.
# Possible: non-negative integer. Use 60 to restore the dataplane image default for load benchmarks.
CF_DATAPLANE_USER_CONFIG_CACHE_EXPIRY_SECONDS=0

# Public nginx port. Default: 8080.
NGINX_PORT=8080

# Admin/test token identity. Defaults shown.
MCP_JWT_SUBJECT=admin@example.com
PLATFORM_ADMIN_EMAIL=admin@example.com
JWT_SECRET_KEY=my-test-key-but-now-longer-than-32-bytes

# Test lane toggles. Defaults shown.
# Possible: true or false.
CF_TEST_ALL_LOCUST=false
CF_TEST_PLUGINS=true

# Locust load defaults. Used by the locust lane.
# The smoke lane stays at 1 user for 10s unless LOCUST_* is set in the shell.
LOCUST_USERS=100
LOCUST_SPAWN_RATE=10
LOCUST_RUN_TIME=5m
