meta {
  name: MCP Call Tools A
  type: http
  seq: 9
}

post {
  url: http://127.0.0.1:{{port1}}/{{path}}
  body: json
  auth: inherit
}

headers {
  Accept: application/json; text/event-stream
  Content-Type: application/json
  mcp-session-id: {{mcp-session-id}}
  Authorization: {{token}}
  Connection: {{connection_action}}
  x-correlation-id: {{x-correlation-id}}
}

body:json {
  {"method":"tools/call","params":{"name":"counter-echo","arguments":{"dkfk":"jdhfj"},"_meta":{"progressToken":2}},"jsonrpc":"2.0","id":2}
}

settings {
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
