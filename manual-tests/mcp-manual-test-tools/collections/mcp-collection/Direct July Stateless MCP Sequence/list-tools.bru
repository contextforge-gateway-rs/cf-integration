meta {
  name: List Tools
  type: http
  seq: 2
}

post {
  url: {{tower_mcp_url}}
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  MCP-Protocol-Version: 2026-07-28
  Mcp-Method: tools/list
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": "tools-list-1",
    "method": "tools/list",
    "params": {
      "_meta": {
        "io.modelcontextprotocol/protocolVersion": "2026-07-28",
        "io.modelcontextprotocol/clientInfo": {
          "name": "bruno-july-stateless-client",
          "version": "0.1.0"
        },
        "io.modelcontextprotocol/clientCapabilities": {}
      }
    }
  }
}

tests {
  const sessionId = res.headers["mcp-session-id"] || res.headers["MCP-Session-Id"] || res.headers["Mcp-Session-Id"];
  const tools = res.body.result && Array.isArray(res.body.result.tools) ? res.body.result.tools : [];
  const names = tools.map((tool) => tool.name);

  test("lists tools over the July stateless path", function () {
    expect(res.status).to.equal(200);
    expect(names).to.include("add");
  });

  test("does not require or return a session", function () {
    expect(sessionId).to.be.undefined;
  });
}
